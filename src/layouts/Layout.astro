---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Beach Money Team — Dein Weg zur ortsunabhängigen Freiheit",
  description = "Baue dir passive Einkommensströme auf, arbeite von überall und lebe das Leben nach deinen Regeln. Getestete Tools, ehrliche Reviews, echte Ergebnisse."
} = Astro.props;
---
<!doctype html>
<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a2c37" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <!-- Affiliate Click Tracking -->
    <script is:inline>
      window.trackClick = function(affiliateId, productName) {
        const data = {
          id: affiliateId,
          product: productName,
          timestamp: new Date().toISOString(),
          referrer: document.referrer,
          path: window.location.pathname
        };

        const clicks = JSON.parse(localStorage.getItem('bmt_clicks') || '[]');
        clicks.push(data);
        localStorage.setItem('bmt_clicks', JSON.stringify(clicks));

        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/track', JSON.stringify(data));
        }

        console.log('[BMT] Click tracked:', data);
      };
    </script>
  </head>
  <body class="bg-ocean-900 text-sand-100 font-body antialiased overflow-x-hidden">
    <slot />
  </body>
</html>
