---
import '../styles/global.css'
import CookieConsent from '../components/CookieConsent.astro'

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Beach Money Team — Dein Weg zur ortsunabhängigen Freiheit",
  description = "Baue dir passive Einkommensströme auf, arbeite von überall und lebe das Leben nach deinen Regeln. Getestete Tools, ehrliche Reviews, echte Ergebnisse.",
  ogImage = "/images/hero-comic-bg.png"
} = Astro.props;

const canonicalUrl = Astro.url.href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Beach Money Team",
  "url": "https://beachmoneyteam.com",
  "description": description,
  "inLanguage": "de",
  "publisher": {
    "@type": "Organization",
    "name": "Beach Money Team",
    "url": "https://beachmoneyteam.com"
  }
};
---
<!doctype html>
<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a2c37" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Vercel Analytics -->
    <script defer src="/_vercel/insights/script.js"></script>
  </head>
  <body class="bg-ocean-900 text-sand-100 font-body antialiased overflow-x-hidden">
    <slot />
    <CookieConsent />
  </body>
</html>
