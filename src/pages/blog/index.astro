---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Blog — Beach Money Team" description="Ehrliche Insights aus dem Digital Nomad Leben. Gear Reviews, Coworking Guides, Remote Work Tipps.">
  <Nav active="blog" />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-ocean-900 via-ocean-800 to-ocean-900"></div>
    <div class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-palm-500/[0.06] rounded-full blur-[128px]"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-sunset-400 mb-4">Blog</span>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-black text-sand-100 mb-6 text-pretty">
        Insights aus dem<br>Nomad-Leben
      </h1>
      <p class="max-w-2xl mx-auto text-lg text-sand-400 leading-relaxed text-pretty">
        Ehrliche Erfahrungen, Gear Reviews und alles was ich auf dem Weg gelernt habe. Kein Clickbait, kein Hype.
      </p>
    </div>
  </section>

  <!-- Blog Posts -->
  <main class="relative pb-24">
    <div class="absolute inset-0 bg-gradient-to-b from-ocean-900 to-ocean-800"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <div class="space-y-8">
        {posts.map((post) => {
          const dateFormatted = new Date(post.data.date).toLocaleDateString('de-DE', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });

          return (
            <a href={`/blog/${post.id}`} class="group block">
              <article class="relative bg-ocean-800/80 backdrop-blur-sm border border-ocean-600/30 rounded-2xl overflow-hidden transition-all duration-300 group-hover:border-ocean-500/50 group-hover:bg-ocean-800">
                {post.data.image && (
                  <div class="aspect-[16/9] overflow-hidden">
                    <img src={post.data.image} alt={post.data.title} width="1200" height="675" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                  </div>
                )}
                <div class="p-8">
                  <div class="flex flex-wrap items-center gap-3 mb-4">
                    <time class="text-xs text-sand-500" datetime={post.data.date}>{dateFormatted}</time>
                    {post.data.tags?.map((tag) => (
                      <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-ocean-600/30 text-sand-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h2 class="font-display text-2xl md:text-3xl font-bold text-sand-100 mb-3 group-hover:text-sunset-400 transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-sand-400 leading-relaxed mb-4">{post.data.description}</p>
                  <span class="inline-flex items-center gap-2 text-sm font-medium text-sunset-400 group-hover:gap-3 transition-all">
                    Weiterlesen <span>&#8594;</span>
                  </span>
                </div>
              </article>
            </a>
          );
        })}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
