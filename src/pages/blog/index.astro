---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const [featured, ...rest] = posts;

const featuredDate = new Date(featured.data.date).toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title="Blog — Beach Money Team" description="Ehrliche Insights aus dem Digital Nomad Leben. Gear Reviews, Coworking Guides, Remote Work Tipps.">
  <Nav active="blog" />

  <!-- Hero -->
  <section class="relative pt-32 pb-12 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-ocean-900 via-ocean-800 to-ocean-900"></div>
    <div class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-palm-500/[0.06] rounded-full blur-[128px]"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
      <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-sunset-400 mb-4 bg-sunset-500/10 border border-sunset-500/20 px-4 py-1.5 rounded-full">Blog</span>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-black text-sand-100 mb-6 text-pretty">
        Insights aus dem<br>Nomad-Leben
      </h1>
      <p class="max-w-2xl mx-auto text-lg text-sand-400 leading-relaxed text-pretty">
        Ehrliche Erfahrungen, Gear Reviews und alles was ich auf dem Weg gelernt habe. Kein Clickbait, kein Hype.
      </p>
    </div>
  </section>

  <!-- Blog Posts -->
  <main class="relative pb-24">
    <div class="absolute inset-0 bg-gradient-to-b from-ocean-900 to-ocean-800"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6">

      <!-- Featured Post — Large Card -->
      <a href={`/blog/${featured.id}`} class="group block mb-12">
        <article class="relative rounded-3xl overflow-hidden border-2 border-ocean-600/30 group-hover:border-sunset-500/40 transition-all duration-500">
          <!-- Image -->
          {featured.data.image && (
            <div class="aspect-[2/1] md:aspect-[5/2] overflow-hidden">
              <img src={featured.data.image} alt={featured.data.title} width="1200" height="675" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
          )}
          <!-- Gradient overlay from bottom -->
          <div class="absolute inset-0 bg-gradient-to-t from-ocean-900 via-ocean-900/60 to-transparent"></div>
          <!-- Content overlaid at bottom -->
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10">
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-sunset-500/90 text-ocean-900">Neuester Beitrag</span>
              <time class="text-xs text-sand-400" datetime={featured.data.date}>{featuredDate}</time>
              {featured.data.tags?.map((tag) => (
                <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-ocean-800/60 backdrop-blur-sm text-sand-300 border border-ocean-600/30">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="font-display text-3xl md:text-4xl font-black text-sand-100 mb-3 group-hover:text-sunset-400 transition-colors">
              {featured.data.title}
            </h2>
            <p class="text-sand-300 leading-relaxed max-w-2xl mb-4 hidden sm:block">{featured.data.description}</p>
            <span class="inline-flex items-center gap-2 text-sm font-bold text-sunset-400 group-hover:gap-3 transition-all">
              Weiterlesen <span>&#8594;</span>
            </span>
          </div>
        </article>
      </a>

      <!-- Rest of posts — Grid Cards -->
      {rest.length > 0 && (
        <div class="grid md:grid-cols-2 gap-6">
          {rest.map((post) => {
            const dateFormatted = new Date(post.data.date).toLocaleDateString('de-DE', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });

            return (
              <a href={`/blog/${post.id}`} class="group block">
                <article class="relative rounded-2xl overflow-hidden border border-ocean-600/30 group-hover:border-sunset-500/30 transition-all duration-500 h-full bg-ocean-800/50">
                  <!-- Image with overlay -->
                  {post.data.image && (
                    <div class="relative aspect-[16/9] overflow-hidden">
                      <img src={post.data.image} alt={post.data.title} width="600" height="338" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                      <div class="absolute inset-0 bg-gradient-to-t from-ocean-900/80 via-transparent to-transparent"></div>
                      <!-- Title overlaid on image -->
                      <div class="absolute bottom-0 left-0 right-0 p-5">
                        <h2 class="font-display text-xl md:text-2xl font-bold text-sand-100 group-hover:text-sunset-400 transition-colors leading-tight">
                          {post.data.title}
                        </h2>
                      </div>
                    </div>
                  )}
                  <!-- Meta + description below -->
                  <div class="p-5 pt-4">
                    <div class="flex flex-wrap items-center gap-2 mb-3">
                      <time class="text-xs text-sand-600" datetime={post.data.date}>{dateFormatted}</time>
                      {post.data.tags?.map((tag) => (
                        <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full bg-ocean-700/50 text-sand-500">
                          {tag}
                        </span>
                      ))}
                    </div>
                    <p class="text-sm text-sand-400 leading-relaxed mb-3">{post.data.description}</p>
                    <span class="inline-flex items-center gap-2 text-sm font-medium text-sunset-400 group-hover:gap-3 transition-all">
                      Lesen <span>&#8594;</span>
                    </span>
                  </div>
                </article>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
