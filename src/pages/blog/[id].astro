---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

// Product recommendations mapped to blog post tags
const productRecs: Record<string, Array<{id: string; title: string; subtitle: string; price: string; link: string; image?: string}>> = {
  'Hardware': [
    { id: 'macbook-air-m4', title: 'MacBook Air M4', subtitle: '24 GB RAM · M4 Chip · 18h Akku', price: 'ab 1.579€', link: 'https://www.amazon.de/dp/B0DZDCH45Q?tag=tapu', image: '/images/products/macbook-air-m4.webp' },
  ],
  'Review': [
    { id: 'macbook-air-m4', title: 'MacBook Air M4', subtitle: '24 GB RAM · M4 Chip · 18h Akku', price: 'ab 1.579€', link: 'https://www.amazon.de/dp/B0DZDCH45Q?tag=tapu', image: '/images/products/macbook-air-m4.webp' },
  ],
  'Koh Phangan': [
    { id: 'sony-wh1000xm5', title: 'Sony WH-1000XM5', subtitle: 'Best-in-Class ANC · 30h Akku', price: '~219€', link: 'https://www.amazon.de/dp/B09Y2MYL5C?tag=tapu', image: '/images/products/sony-wh1000xm5.webp' },
    { id: 'nexstand-k2', title: 'NEXSTAND K2', subtitle: '234g · 8 Stufen · Faltbar', price: '~30€', link: 'https://www.amazon.de/dp/B01HHYQBB8?tag=tapu', image: '/images/products/nexstand-k2.webp' },
  ],
  'Digital Nomad': [
    { id: 'anker-20k-87w', title: 'Anker 20.000mAh (87W)', subtitle: 'Built-in USB-C · MacBook-kompatibel', price: '~40€', link: 'https://www.amazon.de/dp/B0CXDXP8VR?tag=tapu', image: '/images/products/anker-20k-powerbank.webp' },
    { id: 'epicka-adapter', title: 'EPICKA Universal Adapter', subtitle: '200+ Länder · 5 USB Ports', price: '~27€', link: 'https://www.amazon.de/dp/B0CS2TK111?tag=tapu', image: '/images/products/epicka-adapter.webp' },
  ],
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFormatted = new Date(post.data.date).toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Get unique product recommendations based on post tags
const seenIds = new Set<string>();
const recommendations = (post.data.tags || [])
  .flatMap(tag => productRecs[tag] || [])
  .filter(p => {
    if (seenIds.has(p.id)) return false;
    seenIds.add(p.id);
    return true;
  })
  .slice(0, 3);
---

<Layout title={`${post.data.title} — Beach Money Team`} description={post.data.description}>
  <Nav active="blog" />

  <main class="pt-32 pb-24 px-6">
    <article class="max-w-3xl mx-auto">
      <!-- Header -->
      <div class="mb-12">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm text-sand-500 hover:text-sunset-400 transition-colors mb-8">
          <span>&#8592;</span> Alle Beiträge
        </a>
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <time class="text-sm text-sand-500" datetime={post.data.date}>{dateFormatted}</time>
          {post.data.tags?.map((tag) => (
            <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-ocean-600/30 text-sand-400">
              {tag}
            </span>
          ))}
        </div>
        <h1 class="font-display text-4xl md:text-5xl font-black text-sand-100 mb-6 text-pretty leading-tight">
          {post.data.title}
        </h1>
        <p class="text-lg text-sand-400 leading-relaxed">{post.data.description}</p>
      </div>

      <!-- Content -->
      <div class="prose-bmt">
        <Content />
      </div>

      <!-- Product Recommendations -->
      {recommendations.length > 0 && (
        <div class="mt-16 pt-8 border-t border-ocean-700/30">
          <h3 class="font-display text-xl font-bold text-sand-200 mb-6">Erwähnte Produkte</h3>
          <div class="space-y-3">
            {recommendations.map((product) => (
              <div class="group relative bg-ocean-800/80 border border-sunset-500/20 rounded-2xl p-5 transition-all hover:border-sunset-500/40">
                <div class="flex items-center gap-4">
                  {product.image && (
                    <div class="shrink-0 w-16 h-16 rounded-xl overflow-hidden bg-ocean-700/30">
                      <img src={product.image} alt={product.title} width="64" height="64" loading="lazy" class="w-full h-full object-cover" />
                    </div>
                  )}
                  <div class="flex-1 min-w-0">
                    <h4 class="font-display text-base font-bold text-sand-100">{product.title}</h4>
                    <p class="text-xs text-sand-500">{product.subtitle}</p>
                  </div>
                  <div class="shrink-0 flex items-center gap-3">
                    <span class="text-lg font-bold text-sand-200 font-display hidden sm:block">{product.price}</span>
                    <a
                      href={product.link}
                      data-affiliate-id={product.id}
                      data-product-name={product.title}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 bg-sunset-500 hover:bg-sunset-400 text-ocean-900 px-4 py-2 rounded-full text-xs font-bold transition-all hover:scale-105 active:scale-95"
                    >
                      Amazon &#8599;
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <p class="text-[10px] text-sand-600 mt-3">* Affiliate-Links. Für dich ändert sich am Preis nichts.</p>
        </div>
      )}

      <!-- Back + more links -->
      <div class="mt-12 pt-8 border-t border-ocean-700/30 flex flex-wrap items-center justify-between gap-4">
        <a href="/blog" class="inline-flex items-center gap-2 text-sunset-400 hover:text-sunset-300 font-medium transition-colors">
          <span>&#8592;</span> Alle Beiträge
        </a>
        <a href="/gear" class="inline-flex items-center gap-2 text-sand-500 hover:text-sunset-400 font-medium transition-colors text-sm">
          Kompletter Gear Guide <span>&#8594;</span>
        </a>
      </div>
    </article>
  </main>

  <Footer />

  <!-- Affiliate Click Tracking -->
  <script>
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('[data-affiliate-id]') as HTMLElement | null;
      if (!link) return;

      const data = {
        id: link.dataset.affiliateId,
        product: link.dataset.productName,
        timestamp: new Date().toISOString(),
        referrer: document.referrer,
        path: window.location.pathname
      };

      const clicks = JSON.parse(localStorage.getItem('bmt_clicks') || '[]');
      clicks.push(data);
      localStorage.setItem('bmt_clicks', JSON.stringify(clicks));

      if (navigator.sendBeacon) {
        navigator.sendBeacon('/api/track', JSON.stringify(data));
      }
    });
  </script>
</Layout>
