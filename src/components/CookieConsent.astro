---
// GDPR Cookie Consent for Google Fonts (external resource)
---

<div id="cookie-banner" class="hidden fixed bottom-0 left-0 right-0 z-50 p-4">
  <div class="max-w-2xl mx-auto bg-ocean-800/95 backdrop-blur-xl border border-ocean-600/40 rounded-2xl p-6 shadow-2xl">
    <p class="text-sm text-sand-300 leading-relaxed mb-4">
      Diese Website nutzt Google Fonts für die Schriftdarstellung. Dabei werden Daten an Google-Server übermittelt.
      Mehr dazu in unserer <a href="/datenschutz" class="text-sunset-400 underline underline-offset-2">Datenschutzerklärung</a>.
    </p>
    <div class="flex items-center gap-3">
      <button id="cookie-accept" class="bg-sunset-500 hover:bg-sunset-400 text-ocean-900 px-5 py-2 rounded-full text-sm font-bold transition-all hover:scale-105 active:scale-95">
        Verstanden
      </button>
      <button id="cookie-decline" class="text-sm text-sand-500 hover:text-sand-300 transition-colors px-4 py-2">
        Ablehnen
      </button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const declineBtn = document.getElementById('cookie-decline');

  if (!localStorage.getItem('bmt_cookie_consent')) {
    banner?.classList.remove('hidden');
  }

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem('bmt_cookie_consent', 'accepted');
    banner?.classList.add('hidden');
  });

  declineBtn?.addEventListener('click', () => {
    localStorage.setItem('bmt_cookie_consent', 'declined');
    banner?.classList.add('hidden');
  });
</script>
