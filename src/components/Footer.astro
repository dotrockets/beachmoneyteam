---
interface Props {
  activeFooterLink?: 'impressum' | 'datenschutz' | 'affiliate';
}

const { activeFooterLink } = Astro.props;
---

<footer class="relative overflow-hidden">
  <!-- Comic sunset panorama background -->
  <div class="absolute inset-0">
    <img src="/images/comic-footer-bg.webp" alt="" width="1920" height="1080" class="w-full h-full object-cover object-center opacity-50" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-t from-ocean-900/70 via-ocean-900/60 to-ocean-900/80"></div>
  </div>

  <!-- Wavy top border (comic wave) -->
  <div class="absolute top-0 left-0 right-0 overflow-hidden leading-none">
    <svg viewBox="0 0 1200 40" preserveAspectRatio="none" class="w-full h-8 md:h-10">
      <path d="M0,20 C150,40 350,0 500,20 C650,40 850,0 1000,20 C1100,32 1150,15 1200,20 L1200,0 L0,0 Z" fill="#0a2c37" />
    </svg>
  </div>

  <div class="relative z-10 pt-20 pb-10">
    <!-- Main footer content -->
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-[1.5fr_1fr_1fr_1fr] gap-12 mb-16">
        <!-- Brand -->
        <div>
          <a href="/" class="flex items-center gap-3 mb-4 group">
            <span class="text-3xl">🏝️</span>
            <span class="font-display text-2xl font-black text-sand-100 group-hover:text-sunset-400 transition-colors">Beach Money</span>
          </a>
          <p class="text-sm text-sand-300 leading-relaxed mb-6 max-w-xs">
            Dein Guide zum ortsunabhängigen Arbeiten. Ehrliche Reviews, getestete Tools, echte Erfahrungen aus Koh Phangan.
          </p>
          <!-- Social Icons -->
          <div class="flex items-center gap-3">
            <a href="https://instagram.com/beachmoneyteam" target="_blank" rel="noopener noreferrer" class="group/icon size-10 rounded-xl bg-ocean-800/80 border border-ocean-600/30 flex items-center justify-center hover:bg-sunset-500 hover:border-sunset-500 transition-all hover:scale-110" aria-label="Instagram">
              <svg class="size-5 text-sand-400 group-hover/icon:text-ocean-900 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="https://youtube.com/@beachmoneyteam" target="_blank" rel="noopener noreferrer" class="group/icon size-10 rounded-xl bg-ocean-800/80 border border-ocean-600/30 flex items-center justify-center hover:bg-sunset-500 hover:border-sunset-500 transition-all hover:scale-110" aria-label="YouTube">
              <svg class="size-5 text-sand-400 group-hover/icon:text-ocean-900 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href="https://tiktok.com/@beachmoneyteam" target="_blank" rel="noopener noreferrer" class="group/icon size-10 rounded-xl bg-ocean-800/80 border border-ocean-600/30 flex items-center justify-center hover:bg-sunset-500 hover:border-sunset-500 transition-all hover:scale-110" aria-label="TikTok">
              <svg class="size-5 text-sand-400 group-hover/icon:text-ocean-900 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            </a>
            <a href="https://x.com/beachmoneyteam" target="_blank" rel="noopener noreferrer" class="group/icon size-10 rounded-xl bg-ocean-800/80 border border-ocean-600/30 flex items-center justify-center hover:bg-sunset-500 hover:border-sunset-500 transition-all hover:scale-110" aria-label="X / Twitter">
              <svg class="size-5 text-sand-400 group-hover/icon:text-ocean-900 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="/rss.xml" target="_blank" class="group/icon size-10 rounded-xl bg-ocean-800/80 border border-ocean-600/30 flex items-center justify-center hover:bg-sunset-500 hover:border-sunset-500 transition-all hover:scale-110" aria-label="RSS Feed">
              <svg class="size-5 text-sand-400 group-hover/icon:text-ocean-900 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.37 20 6.18 20 5 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
            </a>
          </div>
        </div>

        <!-- Navigation -->
        <div>
          <h3 class="font-display font-bold text-sand-200 mb-4 text-sm uppercase tracking-wider">Seiten</h3>
          <ul class="space-y-2.5">
            <li><a href="/" class="text-sm text-sand-300 hover:text-sunset-400 transition-colors">Home</a></li>
            <li><a href="/gear" class="text-sm text-sand-300 hover:text-sunset-400 transition-colors">Gear Guide</a></li>
            <li><a href="/tools" class="text-sm text-sand-300 hover:text-sunset-400 transition-colors">Tools</a></li>
            <li><a href="/blog" class="text-sm text-sand-300 hover:text-sunset-400 transition-colors">Blog</a></li>
            <li><a href="/about" class="text-sm text-sand-300 hover:text-sunset-400 transition-colors">About</a></li>
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h3 class="font-display font-bold text-sand-200 mb-4 text-sm uppercase tracking-wider">Legal</h3>
          <ul class="space-y-2.5">
            <li><a href="/impressum" class={`text-sm transition-colors ${activeFooterLink === 'impressum' ? 'text-sunset-400' : 'text-sand-300 hover:text-sunset-400'}`}>Impressum</a></li>
            <li><a href="/datenschutz" class={`text-sm transition-colors ${activeFooterLink === 'datenschutz' ? 'text-sunset-400' : 'text-sand-300 hover:text-sunset-400'}`}>Datenschutz</a></li>
            <li><a href="/affiliate-disclaimer" class={`text-sm transition-colors ${activeFooterLink === 'affiliate' ? 'text-sunset-400' : 'text-sand-300 hover:text-sunset-400'}`}>Affiliate Hinweis</a></li>
          </ul>
        </div>

        <!-- Newsletter mini -->
        <div>
          <h3 class="font-display font-bold text-sand-200 mb-4 text-sm uppercase tracking-wider">Newsletter</h3>
          <p class="text-sm text-sand-300 mb-4">Wöchentliche Nomad-Insights direkt in dein Postfach.</p>
          <a href="/#start" class="inline-flex items-center gap-2 bg-sunset-500 hover:bg-sunset-400 text-ocean-900 px-5 py-2.5 rounded-full text-sm font-bold transition-all hover:scale-105 active:scale-95">
            Jetzt anmelden
          </a>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="border-t border-ocean-700/30 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-xs text-sand-400">&copy; 2026 Beach Money Team. Made with 🦀 on Koh Phangan.</p>
        <p class="text-xs text-sand-500">Designed with island vibes & good energy &#127796;</p>
      </div>
    </div>
  </div>
</footer>
